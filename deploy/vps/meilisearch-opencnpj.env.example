# EXAMPLE ONLY — Meilisearch env for 16 GB VPS (plan 02 Phase 5).
# Copy to Meilisearch service environment; tune memory for host.

MEILI_ENV=production
MEILI_MASTER_KEY=change_me_on_vps
MEILI_NO_ANALYTICS=true
# Cap indexing RAM (~6 GB budget on 16 GB host)
MEILI_MAX_INDEXING_MEMORY=6Gb

# API config (config/config.yaml):
# meilisearch.enabled: true
# meilisearch.selective_active_matriz: true
