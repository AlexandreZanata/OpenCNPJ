# EXAMPLE ONLY — do not commit real VPS configs. Copy to the host and edit.
#   sudo cp deploy/vps/sysctl-opencnpj.conf.example /etc/sysctl.d/99-opencnpj.conf
#   sudo sysctl --system
# Tune every value for your RAM, disk, and workload. See deploy/vps/README.md.

# Memory — favor keeping Postgres pages in RAM
vm.swappiness = 1
vm.dirty_ratio = 10
vm.dirty_background_ratio = 3

# Shared memory — align kernel.shmmax with PostgreSQL shared_buffers on the host
kernel.shmmax = 4294967296
kernel.shmall = 2097152

# TCP — API + connection pooler backlog
net.core.somaxconn = 4096
net.ipv4.tcp_max_syn_backlog = 8192
net.ipv4.tcp_fin_timeout = 30
net.ipv4.tcp_keepalive_time = 600
net.ipv4.tcp_keepalive_intvl = 30
net.ipv4.tcp_keepalive_probes = 5
net.ipv4.tcp_tw_reuse = 1
