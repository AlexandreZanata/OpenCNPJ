# EXAMPLE ONLY — starting profile for a ~16 GB RAM VPS. Copy, edit on host, never commit real files.
#   sudo cp deploy/vps/postgresql-opencnpj.conf.example /etc/postgresql/18/main/conf.d/99-opencnpj.conf
# Do NOT copy import-dev Postgres flags from docker-compose.yml (see deploy/vps/README.md).

# --- Memory (adjust to host RAM budget) ---
shared_buffers = 4GB
effective_cache_size = 12GB
work_mem = 64MB
maintenance_work_mem = 2GB
huge_pages = try

# --- Connections (pgBouncer fronts clients) ---
max_connections = 100

# --- WAL / checkpoints (production durability) ---
wal_level = replica
full_page_writes = on
fsync = on
synchronous_commit = on
checkpoint_completion_target = 0.9
checkpoint_timeout = 15min
max_wal_size = 4GB
min_wal_size = 1GB
wal_buffers = 16MB

# --- Planner / SSD ---
default_statistics_target = 100
random_page_cost = 1.1
effective_io_concurrency = 200

# --- Parallelism (scale down on smaller hosts) ---
max_worker_processes = 8
max_parallel_workers = 8
max_parallel_workers_per_gather = 4
max_parallel_maintenance_workers = 4

# --- Partitioning ---
enable_partitionwise_join = on
enable_partitionwise_aggregate = on
enable_partition_pruning = on

# --- Extensions / search ---
shared_preload_libraries = 'pg_stat_statements'
pg_stat_statements.track = all
pg_trgm.similarity_threshold = 0.45

# --- Safety ---
lock_timeout = 30s
statement_timeout = 0
idle_in_transaction_session_timeout = 60000
