# OpenCNPJ API environment (EXAMPLE — copy to /etc/opencnpj/api.env, chmod 600)
# Do not commit real passwords or keys.

CONFIG_FILE=/etc/opencnpj/config.saas.yaml

# Dual PostgreSQL (VPS localhost only)
CNPJ_DATABASE_URL=postgres://opencnpj_reader:CHANGE_ME@127.0.0.1:5432/opencnpj_cnpj?sslmode=disable
SAAS_DATABASE_URL=postgres://opencnpj_saas:CHANGE_ME@127.0.0.1:5432/opencnpj_saas?sslmode=disable

# Redis (usage + MFA challenges)
REDIS_URL=redis://127.0.0.1:6381/0

# Admin secrets (Phase 5+)
# MFA_SECRET_ENCRYPTION_KEY=
# ADMIN_JWT_ACCESS_KEY_PATH=/etc/opencnpj/jwt-access.pem
# ADMIN_JWT_REFRESH_KEY_PATH=/etc/opencnpj/jwt-refresh.pem
