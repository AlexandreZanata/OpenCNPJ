# Nginx — OpenCNPJ on comerc.app.br (EXAMPLE ONLY)
#
# Multi-site VPS: add this file WITHOUT replacing existing vhosts.
#
# Install:
#   sudo cp deploy/saas/cloudflare-real-ip.conf.example /etc/nginx/snippets/cloudflare-real-ip.conf
#   sudo cp deploy/saas/nginx-comerc.app.br.example /etc/nginx/sites-available/opencnpj-comerc
#   sudo ln -sf /etc/nginx/sites-available/opencnpj-comerc /etc/nginx/sites-enabled/
#   sudo certbot certonly --nginx -d api.comerc.app.br -d admin.comerc.app.br
#   sudo nginx -t && sudo systemctl reload nginx
#
# Validate locally (repo):
#   ./scripts/validate_nginx_saas.sh
#
# Replace YOUR_* placeholders. Do not commit real certs or IPs.

limit_req_zone $binary_remote_addr zone=opencnpj_api:10m rate=10r/s;

upstream opencnpj_api {
    server 127.0.0.1:8081;
    keepalive 32;
}

# --- API ---
server {
    listen 443 ssl http2;
    server_name api.comerc.app.br;

    ssl_certificate     /etc/letsencrypt/live/api.comerc.app.br/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.comerc.app.br/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    client_max_body_size 1m;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;

    include /etc/nginx/snippets/cloudflare-real-ip.conf;

    # Health probe — no rate limit (Cloudflare / uptime monitors)
    location = /readyz {
        proxy_pass http://opencnpj_api;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 10s;
    }

    location / {
        limit_req zone=opencnpj_api burst=20 nodelay;
        proxy_pass http://opencnpj_api;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    location /metrics {
        deny all;
        return 404;
    }
}

# --- Admin panel ---
server {
    listen 443 ssl http2;
    server_name admin.comerc.app.br;

    ssl_certificate     /etc/letsencrypt/live/api.comerc.app.br/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.comerc.app.br/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    client_max_body_size 1m;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;

    include /etc/nginx/snippets/cloudflare-real-ip.conf;

    location = /readyz {
        proxy_pass http://opencnpj_api;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 10s;
    }

    location / {
        limit_req zone=opencnpj_api burst=20 nodelay;
        proxy_pass http://opencnpj_api;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }

    location /metrics {
        deny all;
        return 404;
    }
}

# HTTP → HTTPS redirect
server {
    listen 80;
    server_name api.comerc.app.br admin.comerc.app.br;
    return 301 https://$host$request_uri;
}
